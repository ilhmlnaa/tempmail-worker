{
  "name": "tempmail-worker",
  "version": "2.0.0",
  "description": "MAILLDEZ-compatible temp mail API + Web Dashboard on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "db:create": "wrangler d1 create tempmail-db",
    "db:init": "wrangler d1 execute tempmail-db --remote --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.84.1"
  }
}
